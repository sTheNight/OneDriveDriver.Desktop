<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OneDriveDriver.Desktop.App"
             xmlns:local="using:OneDriveDriver.Desktop"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://OneDriveDriver.Desktop/Controls/IconButton.axaml" />
        <StyleInclude Source="avares://OneDriveDriver.Desktop/Controls/GhostButton.axaml" />
    </Application.Styles>
    <Application.Resources>
        <FontFamily x:Key="Noto">
            avares://OneDriveDriver.Desktop/Assets/Fonts#Noto Serif SC
        </FontFamily>
    </Application.Resources>
</Application>