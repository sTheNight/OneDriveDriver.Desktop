<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OneDriveDriver.Desktop.App"
             xmlns:local="using:OneDriveDriver.Desktop"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://OneDriveDriver.Desktop/Resource/MainTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="Vollkorn">avares://OneDriveDriver.Desktop/Assets/Fonts#Vollkorn</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
    
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://OneDriveDriver.Desktop/Controls/GhostIconButton.axaml" />
        <StyleInclude Source="avares://OneDriveDriver.Desktop/Controls/GhostButton.axaml" />
        <StyleInclude Source="avares://OneDriveDriver.Desktop/Controls/PrimaryButton.axaml" />
    </Application.Styles>
</Application>