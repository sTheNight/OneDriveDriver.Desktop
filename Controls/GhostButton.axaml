<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel>
                <Button Classes="GhostButton">
                    Hello World
                </Button>
            </StackPanel>
        </Border>
    </Design.PreviewWith>
    <Style Selector="Button.GhostButton /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource GhostButtonColor}" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.GhostButton:pressed">
        <Setter Property="RenderTransform">
            <ScaleTransform ScaleX="1" ScaleY="1" />
        </Setter>
    </Style>
    <Style Selector="Button.GhostButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource GhostButtonHoverColor}" />
    </Style>
    <Style Selector="Button.GhostButton:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource GhostButtonPressedColor}" />
    </Style>
</Styles>