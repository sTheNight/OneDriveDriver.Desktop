<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush Color="Transparent" x:Key="GhostButtonColor" />
    <SolidColorBrush Color="#0F000000" x:Key="GhostButtonHoverColor" />
    <SolidColorBrush Color="#2F000000" x:Key="GhostButtonPressedColor" />
    <SolidColorBrush Color="LightGray" x:Key="DividerColor" />
    <SolidColorBrush Color="White" x:Key="BackgroundColor" />
</ResourceDictionary>
