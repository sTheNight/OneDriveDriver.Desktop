<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:OneDriveDriver.Desktop.ViewModels"
             xmlns:model="using:OneDriveDriver.Desktop.Models"
             xmlns:converter="using:OneDriveDriver.Desktop.Converters"
             x:DataType="vm:MainViewViewModel"
             x:Class="OneDriveDriver.Desktop.Pages.MainView">
    <UserControl.Resources>
        <converter:IsNullConverter x:Key="NullConverter" />
        <converter:IsNotNullConverter x:Key="NotNullConverter" />
        <converter:ByteSizeToHumanReadableConverter x:Key="ByteSizeToHumanReadableConverter" />
        <converter:ItemToIconConverter x:Key="ItemToIconConverter" />
        <converter:IconColorConverter x:Key="IconColorConverter" />
    </UserControl.Resources>
    <Grid>
        <DockPanel>
            <Border DockPanel.Dock="Top" Padding="8" Margin="0,8,0,0" BorderBrush="LightGray" BorderThickness="1"
                    CornerRadius="8">
                <Panel>
                    <Button Command="{Binding BackCommand}" Classes="IconButton" HorizontalAlignment="Left">
                        <Image Width="16" Height="16" VerticalAlignment="Center"
                               HorizontalAlignment="Center">
                            <Image.Source>
                                <SvgImage
                                    Source="avares://OneDriveDriver.Desktop/Assets/Icons/arrow-left.svg">
                                </SvgImage>
                            </Image.Source>
                        </Image>
                    </Button>
                    <Button Command="{Binding RefreshCommand}" Classes="IconButton" HorizontalAlignment="Right">
                        <Image Width="16" Height="16" VerticalAlignment="Center"
                               HorizontalAlignment="Center">
                            <Image.Source>
                                <SvgImage
                                    Source="avares://OneDriveDriver.Desktop/Assets/Icons/refresh-ccw.svg">
                                </SvgImage>
                            </Image.Source>
                        </Image>
                    </Button>
                </Panel>
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <Panel Classes="FileListPanel" Classes.loading="{Binding IsLoading}">
                    <ItemsControl ItemsSource="{Binding FileList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="model:FileItem">
                                <Border Classes="FileListBorder" BorderBrush="LightGray" BorderThickness="1"
                                        CornerRadius="8" Margin="0,8,0,0" Padding="8"
                                        PointerReleased="OnFileItemPointerReleased">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                        <Border Width="32" Height="32" BorderBrush="LightGray" BorderThickness="1"
                                                VerticalAlignment="Center" CornerRadius="8">
                                            <Image Width="16" Height="16" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center">
                                                <Image.Source>
                                                    <SvgImage
                                                        CurrentColor="{Binding Converter={StaticResource IconColorConverter}}"
                                                        Source="{Binding Converter={StaticResource ItemToIconConverter}}">
                                                    </SvgImage>
                                                </Image.Source>
                                            </Image>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" />
                                            <WrapPanel Margin="0,4,0,0">
                                                <TextBlock Classes="FileInfo" Text="{Binding MimeType}"
                                                           IsVisible="{Binding MimeType, Converter={StaticResource NotNullConverter}}">
                                                </TextBlock>
                                                <TextBlock Classes="FileInfo"
                                                           Text="{Binding ChildCount, StringFormat='{}{0} items'}"
                                                           IsVisible="{Binding ChildCount, Converter={StaticResource NotNullConverter}}" />
                                                <TextBlock Classes="FileInfo"
                                                           Text="{Binding Size,Converter={StaticResource ByteSizeToHumanReadableConverter}}"
                                                           IsVisible="{Binding Size, Converter={StaticResource NotNullConverter}}">
                                                </TextBlock>
                                            </WrapPanel>
                                        </StackPanel>
                                        <Button Grid.Column="2" Classes="IconButton" HorizontalAlignment="Right"
                                                Command="{Binding $parent[ItemsControl].((vm:MainViewViewModel)DataContext).DownloadCommand}"
                                                CommandParameter="{Binding}"
                                                IsVisible="{Binding DownloadUrl,Converter={StaticResource NotNullConverter}}">
                                            <Image Width="16" Height="16" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center">
                                                <Image.Source>
                                                    <SvgImage
                                                        Source="avares://OneDriveDriver.Desktop/Assets/Icons/download.svg">
                                                    </SvgImage>
                                                </Image.Source>
                                            </Image>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Panel>
            </ScrollViewer>
        </DockPanel>
        <Border Classes="LoadingOverlay"
                Classes.active="{Binding IsLoading}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ZIndex="100"
                Background="#3Fffffff">
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Text="Loading..." />
        </Border>
    </Grid>
    <UserControl.Styles>
        <Style Selector="TextBlock.FileInfo">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <!-- LoadingOverlay -->
        <Style Selector="Border.LoadingOverlay">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.LoadingOverlay.active">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>
        <!-- File List Panel -->
        <Style Selector="Panel.FileListPanel.loading">
            <Setter Property="Effect">
                <BlurEffect Radius="8"></BlurEffect>
            </Setter>
        </Style>
        <Style Selector="Panel.FileListPanel">
            <Setter Property="Transitions">
                <Transitions>
                    <EffectTransition Property="Effect" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <!-- Icon Button -->
        <Style Selector="Button.IconButton /template/ ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:00.1" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.IconButton:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.IconButton /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.IconButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0F000000"></Setter>
        </Style>
        <Style Selector="Button.IconButton:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#2F000000"></Setter>
        </Style>
        <!-- FileListBorder -->
        <Style Selector="Border.FileListBorder">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1"></BrushTransition>
                </Transitions>
            </Setter>
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.FileListBorder:pointerover">
            <Setter Property="Background" Value="#0F000000" />
        </Style>
    </UserControl.Styles>
</UserControl>
