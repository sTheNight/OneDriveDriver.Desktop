<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:OneDriveDriver.Desktop.ViewModels"
             x:DataType="vm:ConfigViewViewModel"
             x:Class="OneDriveDriver.Desktop.Pages.ConfigView">
    <StackPanel>
        <TextBlock>I'm ConfigView</TextBlock>
        <Button Command="{Binding PushToMainViewCommand}" Content="Push to MainView"/>
    </StackPanel>
</UserControl>
